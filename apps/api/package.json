{
  "name": "@sadoksan/api",
  "version": "0.0.1",
  "description": "NestJS backend API for Sciveto ERP",
  "author": "Sadoksan",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "predev": "node -e \"const fs=require('fs'); const rm=(p)=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){if(e.code!=='ENOENT'&&e.code!=='EBUSY')throw e}}; rm('dist'); rm('tsconfig.tsbuildinfo');\"",
    "dev": "nest start --watch --preserveWatchOutput",
    "start": "node dist/main",
    "prebuild": "prisma generate",
    "build": "nest build",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true});\"",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/axios": "3.1.1",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/schedule": "6.1.3",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "axios": "1.16.0",
    "bcryptjs": "3.0.3",
    "bullmq": "5.76.5",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "express-rate-limit": "7.5.1",
    "helmet": "8.0.0",
    "multer": "1.4.5-lts.1",
    "dotenv": "17.4.2",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.20.0",
    "redis": "5.12.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "@types/passport-jwt": "4.0.1",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "eslint": "10.3.0",
    "jest": "30.3.0",
    "prisma": "7.8.0",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3"
  },
  "type": "commonjs"
}
