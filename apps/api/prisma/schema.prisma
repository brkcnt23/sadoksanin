// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Prisma 7+: connection URL is no longer declared here.
// Migrate URL lives in `prisma.config.ts`; runtime URL is passed via the
// driver adapter (PrismaPg) in `src/common/prisma.service.ts`.
datasource db {
  provider = "postgresql"
}

// ───── Auth & Users ──────────────────────────────────────────────────────────
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String // bcrypted
  name      String
  role      UserRole   @default(DEALER)

  // Dealer/customer data (B2B-only system)
  phone     String?
  address   String?
  city      String?

  // Relationships
  dealer    Dealer?    @relation("DealerAccount")
  assignedDealers Dealer[] @relation("DealerSalesRep") // Plasiyer'in sorumlu olduğu bayiler
  orders    Order[]
  favorites Favorite[]

  // Cart
  cartItems  CartItem[]

  // Saved addresses
  addresses Address[]

  // Stock movements
  stockMovements StockMovement[]
  bankTransfers  BankTransfer[]

  // Audit
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([email])
  @@index([role])
}

// ───── Address Book ──────────────────────────────────────────────────────────
model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   // "Ev", "İş", "Depo" etc.
  address   String   // Full address line
  city      String
  district  String?
  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ───── Cart ──────────────────────────────────────────────────────────────────
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

enum UserRole {
  DEALER    // B2B dealer (B2B-only system)
  PLASIYER  // Sales representative — proforma + reports, no pricing
  ADMIN
  SUPER_ADMIN
}

// ───── Dealers (B2B Accounts) ────────────────────────────────────────────────
model Dealer {
  id                String      @id @default(cuid())
  userId            String      @unique
  user              User        @relation("DealerAccount", fields: [userId], references: [id], onDelete: Cascade)

  // Sorumlu plasiyer (satış temsilcisi) — bayi başına tek plasiyer
  salesRepId        String?
  salesRep          User?       @relation("DealerSalesRep", fields: [salesRepId], references: [id], onDelete: SetNull)

  // Business info
  name              String
  company           String
  taxNo             String      @unique
  taxOffice         String

  // Netsis link
  cariNo            String      @unique // Customer account number in Netsis
  cariValidated     Boolean     @default(false)

  // Contact
  contactPerson     String
  phone             String

  // Delivery
  city              String
  region            String      @default("Marmara") // Logistics region
  address           String

  // Account state
  status            DealerStatus @default(PENDING)
  cariBalance       Float       @default(0) // From Netsis (negative = owes us)
  creditLimit       Float       @default(0)

  // Stats
  totalOrders       Int         @default(0)
  totalRevenue      Float       @default(0)
  riskScore         Int         @default(0)
  riskLevel         String      @default("LOW")
  lastOrderAt       DateTime?

  // Admin notes
  approvedAt        DateTime?
  approvedBy        String?
  rejectionReason   String?

  // Relationships
  orders             Order[]
  balanceTransactions BalanceTransaction[]

  // Audit
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([cariNo])
  @@index([status])
  @@index([salesRepId])
}

enum DealerStatus {
  PENDING   // Awaiting approval
  ACTIVE
  INACTIVE
  REJECTED
}

// ───── Categories ─────────────────────────────────────────────────────────────
model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  imageUrl    String?
  order       Int        @default(0) // Sıralama
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ───── Brands ─────────────────────────────────────────────────────────────────
model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  logoUrl     String?
  products    Product[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ───── Products (from Netsis) ────────────────────────────────────────────────
model Product {
  id                String       @id @default(cuid())
  netsisCode        String       @unique // Master ID from Netsis
  sku               String       @unique
  name              String
  brand             String       // Denormalized for fast reads (sync from Brand)
  category          String       // Denormalized for fast reads (sync from Category)
  brandId           String?
  brandRel          Brand?       @relation(fields: [brandId], references: [id])
  categoryId        String?
  categoryRel       Category?    @relation(fields: [categoryId], references: [id])
  description       String?

  // Visual assets (used in proforma PDF, product cards, etc.)
  // imageUrl = primary cover image. images[] = gallery (JSON array of URLs).
  imageUrl          String?
  images            String?   // JSON array: ["url1","url2",...]

  // Pricing & Tax
  basePrice         Float
  taxRate           Float        @default(0.2) // 0.20 = 20% VAT

  // Physical
  unit              String       // m², adet, kg, etc
  weight            Float?
  dimensions        String?

  // Stock (from Netsis, updated hourly)
  netsisStock           Int          @default(0)
  netsisPendingQuantity Int          @default(0) // Netsis'te bekleyen (faturası kesilmemiş)
  reservedStock         Int          @default(0) // Sum of pending orders
  displayStock          Int          @default(0) // netsisStock - netsisPendingQuantity - reservedStock
  lastNetsisSync        DateTime     @default(now())

  // Stock thresholds
  minimumStock      Int          @default(0) // Red alert threshold
  middleStock       Int?                      // Orange alert (optional)

  // Visibility/Purchasability
  visible           Boolean      @default(true)
  purchasable       Boolean      @default(true)
  isFeatured        Boolean      @default(false) // Öne çıkan ürün — ana sayfada gösterilir

  // Sync status
  syncStatus        SyncStatus   @default(NEVER)

  // Relationships
  variations        ProductVariation[]
  orderLines        OrderLine[]
  favorites         Favorite[]
  cartItems         CartItem[]
  stockReservations StockReservation[]
  stockMovements    StockMovement[]

  // Audit
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([netsisCode])
  @@index([sku])
  @@index([category])
  @@index([brandId])
  @@index([categoryId])
  @@index([syncStatus])
  @@index([isFeatured])
}

enum SyncStatus {
  SYNCED
  PENDING
  ERROR
  NEVER
}

model ProductVariation {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku         String
  label       String    // "60x120cm Beige"
  attributes  String    // JSON: { "size": "60x120", "color": "Beige" }
  price       Float?    // null = inherit parent
  stock       Int       @default(0)
  images      String?   // JSON array: ["url1","url2",...]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, sku])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ───── Orders ────────────────────────────────────────────────────────────────
model Order {
  id                String      @id @default(cuid())
  orderNo           String      @unique // SDK-2026-0001

  // Customer info
  customerId        String
  customer          User        @relation(fields: [customerId], references: [id])
  customerType      CustomerType
  dealerId          String?     // If B2B
  dealer            Dealer?     @relation(fields: [dealerId], references: [id])

  // Shipping
  shippingCity      String
  shippingAddress   String

  // Order content
  lines             OrderLine[]
  subtotal          Float
  tax               Float
  logisticsSurcharge Float @default(0)
  total             Float

  // Status — application code always sets this explicitly on creation
  // (B2B → PENDING_APPROVAL, B2C → APPROVED). The default is a defensive
  // fallback for raw inserts; PENDING_APPROVAL is the conservative choice
  // since it requires explicit admin action to progress.
  status            OrderStatus @default(PENDING_APPROVAL)

  // B2B approval
  approvedAt        DateTime?
  approvedBy        String?
  rejectionReason   String?
  completedAt       DateTime?

  // E-document tracking (Alneo entegratör)
  eInvoiceNo        String?
  eInvoiceStatus    EInvoiceStatus?
  eArchiveNo        String?
  eArchiveStatus    EInvoiceStatus?
  eIrsaliyeNo       String?
  edocumentLogs     EdocumentLog[]

  // Shipment tracking
  trackingNumber    String?
  cargoCompany      String?

  // Promo
  promoCode         String?
  discountAmount    Float     @default(0)

  // Payment
  paymentMethod     String?   // CREDIT_CARD or BANK_TRANSFER
  paymentStatus     PaymentStatus?

  // Notes
  notes             String?
  adminNotes        Json?     // [{ note, userId, userEmail, createdAt }]

  // Stock reservation
  stockReservations StockReservation[]
  balanceTransactions BalanceTransaction[]
  bankTransfers      BankTransfer[]
  statusHistory     OrderStatusHistory[]

  // Financial tracking
  invoiceCut        Boolean     @default(false)
  invoiceNo         String?
  invoiceDate       DateTime?
  cashCollected     Boolean     @default(false)
  cashCollectedAt   DateTime?
  deliveryNoteCut   Boolean     @default(false)

  // Audit
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([customerId])
  @@index([dealerId])
  @@index([status])
  @@index([orderNo])
}

enum CustomerType {
  B2C
  B2B
}

enum OrderStatus {
  PENDING_APPROVAL // B2B awaiting admin approval
  APPROVED
  PREPARING
  SHIPPED
  COMPLETED
  CANCELLED
  REJECTED
  RETURN_REQUESTED
  RETURNED
}

enum EInvoiceStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model OrderLine {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId     String
  product       Product  @relation(fields: [productId], references: [id])

  variationId   String?
  quantity      Int
  unitPrice     Float
  taxRate       Float
  total         Float // qty * unitPrice * (1 + taxRate)

  createdAt     DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// ───── Bank Transfer ─────────────────────────────────────────────────────────
model BankTransfer {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id])
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  bank            String
  amount          Float
  senderName      String
  note            String?
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())

  @@index([orderId])
  @@index([status])
}

// ───── Order Status History ────────────────────────────────────────────────────
model OrderStatusHistory {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      String   // PENDING_APPROVAL, APPROVED, SHIPPED, etc
  note        String?  // Optional note (e.g. rejection reason, tracking number)
  actorId     String?  // Who changed it (admin/user ID)
  actorEmail  String?  // Email at time of change
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

// ───── Stock Management ──────────────────────────────────────────────────────
model StockReservation {
  id            String              @id @default(cuid())
  orderId       String
  order         Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId     String
  product       Product             @relation(fields: [productId], references: [id])

  quantity      Int
  status        StockReservationStatus @default(ACTIVE)

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([status])
}

enum StockReservationStatus {
  ACTIVE
  RELEASED   // Order cancelled
  FULFILLED  // Order shipped
}

// ───── Sync tracking ────────────────────────────────────────────────────────
model NetsisSync {
  id                String    @id @default(cuid())
  syncType          String    // "products", "stock", "cari"

  lastSyncAt        DateTime?
  lastSyncDuration  Int       @default(0) // milliseconds
  itemsSynced       Int       @default(0)
  errors            Int       @default(0)
  status            String    @default("idle") // idle, running, success, error
  nextScheduledAt   DateTime?

  errorMessage      String?

  updatedAt         DateTime  @updatedAt

  @@unique([syncType])
}

// ───── Pricing & Logistics (from Admin) ──────────────────────────────────────
model RegionalPricingSurcharge {
  id            String    @id @default(cuid())
  regionKey     String    @unique // Marmara, Ege, IcAnadolu, etc
  surcharge     Float
  description   String
  active        Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProvincePricingSurcharge {
  id            String    @id @default(cuid())
  province      String    @unique // İstanbul, Ankara, etc
  surcharge     Float
  description   String
  active        Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model LogisticsRule {
  id                    String    @id @default(cuid())
  region                String
  cities                String[]  // JSON array
  baseSurcharge         Float     @default(0)
  perKgSurcharge        Float     @default(0)
  perM2Surcharge        Float     @default(0)
  freeShippingThreshold Float?
  active                Boolean   @default(true)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ───── Forex ────────────────────────────────────────────────────────────────
model ExchangeRate {
  id              String    @id @default(cuid())
  currency        String    @unique // USD, EUR, GBP, CHF, AED

  rate            Float     // Base rate (TRY per currency)
  liveRate        Float?    // From TCMB/API
  manualOverride  Float?    // User-set rate (takes precedence)

  source          String    @default("manual")
  lastUpdated     DateTime  @default(now())

  updatedAt       DateTime  @updatedAt
}

model ProductCurrencyPrice {
  id          String    @id @default(cuid())
  productId   String
  currency    String    // USD, EUR, etc
  price       Float     // Price in foreign currency

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, currency])
  @@index([productId])
}

// ───── Dealer Balance (Açık Hesap) ──────────────────────────────────────────
model BalanceTransaction {
  id            String   @id @default(cuid())
  dealerId      String
  dealer        Dealer   @relation(fields: [dealerId], references: [id])
  orderId       String?
  order         Order?   @relation(fields: [orderId], references: [id])
  type          String   // "DEBIT" (borç/alış), "CREDIT" (ödeme/tahsilat), "ADJUSTMENT"
  amount        Float    // pozitif her zaman
  balanceBefore Float
  balanceAfter  Float
  description   String?
  referenceType String?  // "Order", "Payment", "Manual"
  referenceId   String?
  createdAt     DateTime @default(now())

  @@index([dealerId])
  @@index([createdAt])
}

// ───── E-Document Log (e-Fatura, e-Arşiv, e-İrsaliye) ───────────────────────
model EdocumentLog {
  id              String    @id @default(cuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id])
  documentType    String    // "EINVOICE", "EARCHIVE", "EIRSALIYE"
  status          String    @default("PENDING") // PENDING, SUBMITTED, ACCEPTED, REJECTED
  externalId      String?   // Entegratörün verdiği belge no
  externalUuid    String?   // Entegratörün verdiği UUID
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  submittedAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([orderId])
  @@index([status])
}

// ───── Settings ──────────────────────────────────────────────────────────────
model SiteSettings {
  id                    String    @id @default("main") // Single record

  maintenanceMode       Boolean   @default(false)
  maintenanceMessage    String?
  maintenanceAllowAdmins Boolean  @default(true)

  // Integration placeholders (API anahtarları gelince doldurulacak)
  alneoApiUrl           String?
  alneoApiKey           String?
  albarakaApiUrl        String?
  albarakaMerchantId    String?
  netsisApiUrl          String?
  netsisUsername        String?
  whatsappNumber        String?
  introEnabled          Boolean   @default(true)

  updatedAt             DateTime  @updatedAt
}

// ───── Proforma Invoices ────────────────────────────────────────────────────
model Proforma {
  id                           String   @id @default(cuid())
  proformaNumber               String   @unique
  dealerId                     String?
  customerId                   String?
  customerName                 String
  customerAddress              String
  customerCity                 String
  customerPhone                String?
  customerEmail                String?

  // Status workflow: draft → pending_approval → approved → downloaded
  //                  draft → pending_approval → rejected (→ draft on resubmit)
  status                       String   @default("draft")
  templateType                 String   @default("LOCAL")

  companyName                  String
  companyAddress               String
  companyPhone                 String
  companyEmail                 String
  companyBank                  String?
  companyBankAccount           String?

  // International export fields
  internationalInvoiceNumber   String?
  internationalInvoiceDate     DateTime?
  exporterRef                  String?
  countryOrigin                String?
  countryDestination           String?
  preCarriage                  String?
  portLoading                  String?
  portDischarge                String?
  vessel                       String?

  subtotal                     Decimal  @db.Decimal(12, 2) @default(0)
  shipping                     Decimal  @db.Decimal(12, 2) @default(0)
  tax                          Decimal  @db.Decimal(12, 2) @default(0)
  totalAmount                  Decimal  @db.Decimal(12, 2) @default(0)

  pdfUrl                       String?
  pdfGeneratedAt               DateTime?

  generatedBy                  String?
  generatedByRole              String?   // "ADMIN" | "PLASIYER" — who created this
  generatedAt                  DateTime @default(now())

  // Approval workflow (plasiyer → admin)
  submittedForApproval         Boolean  @default(false)
  submittedAt                  DateTime?
  approvedBy                   String?
  approvedAt                   DateTime?
  rejectedBy                   String?
  rejectedAt                   DateTime?
  rejectionReason              String?
  isDownloaded                 Boolean  @default(false)
  watermarkEnabled             Boolean  @default(true)

  viewedAt                     DateTime?
  downloadedAt                 DateTime?

  items                        ProformaItem[]

  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@index([dealerId])
  @@index([customerId])
  @@index([templateType])
  @@index([generatedAt])
  @@index([status])
  @@index([generatedBy])
}

model ProformaItem {
  id           String   @id @default(cuid())
  proformaId   String
  proforma     Proforma @relation(fields: [proformaId], references: [id], onDelete: Cascade)

  sku          String
  productName  String
  description  String
  brand        String?

  quantity     Decimal  @db.Decimal(10, 2)
  unitPrice    Decimal  @db.Decimal(10, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)

  imageUrl     String?

  createdAt    DateTime @default(now())

  @@index([proformaId])
  @@index([sku])
}

// ───── Promo Codes ─────────────────────────────────────────────────────────
model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  discountType    String    @default("PERCENTAGE") // PERCENTAGE | FIXED_AMOUNT
  discountValue   Decimal   @default(0) @db.Decimal(10,2)
  minOrderAmount  Decimal?  @db.Decimal(12,2)
  usageLimit      Int       @default(0)
  usedCount       Int       @default(0)
  dealerOnly      Boolean   @default(false)
  dealerId        String?
  isActive        Boolean   @default(true)
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

// ───── Site Content (CMS) ──────────────────────────────────────────────────
model SiteContent {
  id          String   @id @default("hero")
  headline    String   @default("Premium işçilik, profesyonel tedarik.")
  subheading  String   @default("23 yıllık tecrübemizle, 4000+ ürün ve 50+ markayı Türkiye genelinde 300+ bayiye ulaştırıyoruz.")
  imageUrl    String?
  ctaText     String   @default("Ürünleri Keşfedin")
  ctaLink     String   @default("/urunler")
  secondaryCtaText String? @default("Bayi Olun")
  secondaryCtaLink String? @default("/bayilik")
  stats       String?  // JSON: [{label:"23+ Yıl",value:"Tecrübe"},...]
  updatedAt   DateTime @updatedAt
}

// ───── Discounts ───────────────────────────────────────────────────────────
model Discount {
  id           String       @id @default(cuid())
  type         DiscountType
  targetId     String       // Product ID, category slug, or brand slug
  targetName   String       // Display name
  discountType DiscountKind @default(PERCENTAGE)
  value        Float
  isActive     Boolean      @default(true)
  validFrom    DateTime     @default(now())
  validUntil   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([type])
  @@index([isActive])
}

enum DiscountType {
  PRODUCT
  CATEGORY
  BRAND
}

enum DiscountKind {
  PERCENTAGE
  FIXED_AMOUNT
}

// ───── Popup / Campaign Management ────────────────────────────────────────────
model Popup {
  id            String        @id @default(cuid())
  title         String
  bodyHtml      String?
  imageUrl      String?
  ctaText       String?
  ctaUrl        String?
  audience      PopupAudience @default(ALL)
  dealerIds     String[]      @default([]) // Specific dealer IDs when audience=SPECIFIC_DEALER
  isActive      Boolean       @default(false)
  showOnce      Boolean       @default(true)
  startDate     DateTime?
  endDate       DateTime?
  impressions   Int           @default(0)
  clicks        Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([isActive])
  @@index([audience])
}

enum PopupAudience {
  ALL
  B2C
  B2B
  SPECIFIC_DEALER
}

// ───── SEO Redirects ────────────────────────────────────────────────────────
model SeoRedirect {
  id        String   @id @default(cuid())
  oldUrl    String   @unique
  newUrl    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([oldUrl])
}

// ───── CMS Pages ────────────────────────────────────────────────────────────
model CmsPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text // HTML rich text
  isActive    Boolean  @default(true)
  seoTitle    String?
  seoMeta     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

// ───── Notify Requests (Back-in-stock) ────────────────────────────────────────
model NotifyRequest {
  id          String   @id @default(cuid())
  productId   String
  userId      String
  channel     String   @default("email") // email, whatsapp
  status      String   @default("pending") // pending, notified, cancelled
  createdAt   DateTime @default(now())
  notifiedAt  DateTime?

  @@unique([productId, userId, channel])
  @@index([productId])
  @@index([status])
}

// ───── Audit ─────────────────────────────────────────────────────────────────
model AuditLog {
  id          String    @id @default(cuid())
  userId      String?   // Who did it
  email       String?   // Email at time

  action      String    // product.update, order.approve, etc
  entity      String    // Product, Order, Dealer
  entityId    String    // ID of the entity

  oldValue    String?   // JSON
  newValue    String?   // JSON

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
}

// ───── Stock Movements (append-only audit log) ───────────────────────────────
model StockMovement {
  id            String             @id @default(cuid())
  productId     String
  product       Product            @relation(fields: [productId], references: [id])
  type          StockMovementType
  quantity      Int                // delta: pozitif=giriş, negatif=çıkış
  oldStock      Int                // işlem öncesi netsisStock
  newStock      Int                // işlem sonrası netsisStock
  userId        String?
  user          User?              @relation(fields: [userId], references: [id])
  referenceType String?            // "Order", "Return", "Manual", "CountAdjust"
  referenceId   String?            // Order ID, Return ID vs
  note          String?
  createdAt     DateTime           @default(now())

  @@index([productId])
  @@index([createdAt])
  @@index([type])
}

enum StockMovementType {
  MANUAL_ENTRY
  MANUAL_EXIT
  ORDER_RESERVE
  ORDER_FULFILL
  ORDER_CANCEL
  RETURN_RESTOCK
  COUNT_ADJUST
  DAMAGE_LOSS
}
