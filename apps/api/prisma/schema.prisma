// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Prisma 7+: connection URL is no longer declared here.
// Migrate URL lives in `prisma.config.ts`; runtime URL is passed via the
// driver adapter (PrismaPg) in `src/common/prisma.service.ts`.
datasource db {
  provider = "postgresql"
}

// ───── Auth & Users ──────────────────────────────────────────────────────────
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String // bcrypted
  name      String
  role      UserRole   @default(CUSTOMER)

  // B2C customer data
  phone     String?
  address   String?
  city      String?

  // Relationships
  dealer    Dealer?
  orders    Order[]
  favorites Favorite[]

  // Saved addresses
  addresses Address[]

  // Audit
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([email])
  @@index([role])
}

// ───── Address Book ──────────────────────────────────────────────────────────
model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   // "Ev", "İş", "Depo" etc.
  address   String   // Full address line
  city      String
  district  String?
  isDefault Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum UserRole {
  CUSTOMER  // B2C customer
  DEALER    // B2B dealer/reseller
  ADMIN
  SUPER_ADMIN
}

// ───── Dealers (B2B Accounts) ────────────────────────────────────────────────
model Dealer {
  id                String      @id @default(cuid())
  userId            String      @unique
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business info
  name              String
  company           String
  taxNo             String      @unique
  taxOffice         String

  // Netsis link
  cariNo            String      @unique // Customer account number in Netsis
  cariValidated     Boolean     @default(false)

  // Contact
  contactPerson     String
  phone             String

  // Delivery
  city              String
  region            String      @default("Marmara") // Logistics region
  address           String

  // Account state
  status            DealerStatus @default(PENDING)
  cariBalance       Float       @default(0) // From Netsis (negative = owes us)
  creditLimit       Float       @default(0)

  // Stats
  totalOrders       Int         @default(0)
  totalRevenue      Float       @default(0)
  lastOrderAt       DateTime?

  // Admin notes
  approvedAt        DateTime?
  approvedBy        String?
  rejectionReason   String?

  // Relationships
  orders            Order[]

  // Audit
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([cariNo])
  @@index([status])
}

enum DealerStatus {
  PENDING   // Awaiting approval
  ACTIVE
  INACTIVE
  REJECTED
}

// ───── Categories ─────────────────────────────────────────────────────────────
model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  order       Int       @default(0) // Sıralama
  products    Product[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ───── Brands ─────────────────────────────────────────────────────────────────
model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  logoUrl     String?
  products    Product[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ───── Products (from Netsis) ────────────────────────────────────────────────
model Product {
  id                String       @id @default(cuid())
  netsisCode        String       @unique // Master ID from Netsis
  sku               String       @unique
  name              String
  brand             String       // Denormalized for fast reads (sync from Brand)
  category          String       // Denormalized for fast reads (sync from Category)
  brandId           String?
  brandRel          Brand?       @relation(fields: [brandId], references: [id])
  categoryId        String?
  categoryRel       Category?    @relation(fields: [categoryId], references: [id])
  description       String?

  // Visual assets (used in proforma PDF, product cards, etc.)
  // imageUrl = primary cover image. images[] = gallery (JSON array of URLs).
  imageUrl          String?
  images            String?   // JSON array: ["url1","url2",...]

  // Pricing & Tax
  basePrice         Float
  taxRate           Float        @default(0.2) // 0.20 = 20% VAT

  // Physical
  unit              String       // m², adet, kg, etc
  weight            Float?
  dimensions        String?

  // Stock (from Netsis, updated hourly)
  netsisStock       Int          @default(0)
  reservedStock     Int          @default(0) // Sum of pending orders
  displayStock      Int          @default(0) // calculated: netsis - reserved
  lastNetsisSync    DateTime     @default(now())

  // Stock thresholds
  minimumStock      Int          @default(0) // Red alert threshold
  middleStock       Int?                      // Orange alert (optional)

  // Visibility/Purchasability
  visible           Boolean      @default(true)
  purchasable       Boolean      @default(true)

  // Sync status
  syncStatus        SyncStatus   @default(NEVER)

  // Relationships
  variations        ProductVariation[]
  orderLines        OrderLine[]
  favorites         Favorite[]
  stockReservations StockReservation[]

  // Audit
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([netsisCode])
  @@index([sku])
  @@index([category])
  @@index([brandId])
  @@index([categoryId])
  @@index([syncStatus])
}

enum SyncStatus {
  SYNCED
  PENDING
  ERROR
  NEVER
}

model ProductVariation {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku         String
  label       String    // "60x120cm Beige"
  attributes  String    // JSON: { "size": "60x120", "color": "Beige" }
  price       Float?    // null = inherit parent
  stock       Int       @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, sku])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ───── Orders ────────────────────────────────────────────────────────────────
model Order {
  id                String      @id @default(cuid())
  orderNo           String      @unique // SDK-2026-0001

  // Customer info
  customerId        String
  customer          User        @relation(fields: [customerId], references: [id])
  customerType      CustomerType
  dealerId          String?     // If B2B
  dealer            Dealer?     @relation(fields: [dealerId], references: [id])

  // Shipping
  shippingCity      String
  shippingAddress   String

  // Order content
  lines             OrderLine[]
  subtotal          Float
  tax               Float
  logisticsSurcharge Float @default(0)
  total             Float

  // Status — application code always sets this explicitly on creation
  // (B2B → PENDING_APPROVAL, B2C → APPROVED). The default is a defensive
  // fallback for raw inserts; PENDING_APPROVAL is the conservative choice
  // since it requires explicit admin action to progress.
  status            OrderStatus @default(PENDING_APPROVAL)

  // B2B approval
  approvedAt        DateTime?
  approvedBy        String?
  rejectionReason   String?
  completedAt       DateTime?

  // E-document tracking
  eInvoiceNo        String?
  eInvoiceStatus    EInvoiceStatus?
  eIrsaliyeNo       String?

  // Promo
  promoCode         String?
  discountAmount    Float     @default(0)

  // Payment
  paymentMethod     String?   // CREDIT_CARD or BANK_TRANSFER
  paymentStatus     PaymentStatus?

  // Notes
  notes             String?

  // Stock reservation
  stockReservations StockReservation[]
  statusHistory     OrderStatusHistory[]

  // Audit
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([customerId])
  @@index([dealerId])
  @@index([status])
  @@index([orderNo])
}

enum CustomerType {
  B2C
  B2B
}

enum OrderStatus {
  PENDING_APPROVAL // B2B awaiting admin approval
  APPROVED
  PREPARING
  SHIPPED
  COMPLETED
  CANCELLED
  REJECTED
  RETURN_REQUESTED
  RETURNED
}

enum EInvoiceStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model OrderLine {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId     String
  product       Product  @relation(fields: [productId], references: [id])

  variationId   String?
  quantity      Int
  unitPrice     Float
  taxRate       Float
  total         Float // qty * unitPrice * (1 + taxRate)

  createdAt     DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// ───── Order Status History ────────────────────────────────────────────────────
model OrderStatusHistory {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      String   // PENDING_APPROVAL, APPROVED, SHIPPED, etc
  note        String?  // Optional note (e.g. rejection reason, tracking number)
  actorId     String?  // Who changed it (admin/user ID)
  actorEmail  String?  // Email at time of change
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

// ───── Stock Management ──────────────────────────────────────────────────────
model StockReservation {
  id            String              @id @default(cuid())
  orderId       String
  order         Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId     String
  product       Product             @relation(fields: [productId], references: [id])

  quantity      Int
  status        StockReservationStatus @default(ACTIVE)

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([status])
}

enum StockReservationStatus {
  ACTIVE
  RELEASED   // Order cancelled
  FULFILLED  // Order shipped
}

// ───── Sync tracking ────────────────────────────────────────────────────────
model NetsisSync {
  id                String    @id @default(cuid())
  syncType          String    // "products", "stock", "cari"

  lastSyncAt        DateTime?
  lastSyncDuration  Int       @default(0) // milliseconds
  itemsSynced       Int       @default(0)
  errors            Int       @default(0)
  status            String    @default("idle") // idle, running, success, error
  nextScheduledAt   DateTime?

  errorMessage      String?

  updatedAt         DateTime  @updatedAt

  @@unique([syncType])
}

// ───── Pricing & Logistics (from Admin) ──────────────────────────────────────
model RegionalPricingSurcharge {
  id            String    @id @default(cuid())
  regionKey     String    @unique // Marmara, Ege, IcAnadolu, etc
  surcharge     Float
  description   String
  active        Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProvincePricingSurcharge {
  id            String    @id @default(cuid())
  province      String    @unique // İstanbul, Ankara, etc
  surcharge     Float
  description   String
  active        Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model LogisticsRule {
  id                    String    @id @default(cuid())
  region                String
  cities                String[]  // JSON array
  baseSurcharge         Float     @default(0)
  perKgSurcharge        Float     @default(0)
  perM2Surcharge        Float     @default(0)
  freeShippingThreshold Float?
  active                Boolean   @default(true)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ───── Forex ────────────────────────────────────────────────────────────────
model ExchangeRate {
  id              String    @id @default(cuid())
  currency        String    @unique // USD, EUR, GBP, CHF, AED

  rate            Float     // Base rate (TRY per currency)
  liveRate        Float?    // From TCMB/API
  manualOverride  Float?    // User-set rate (takes precedence)

  source          String    @default("manual")
  lastUpdated     DateTime  @default(now())

  updatedAt       DateTime  @updatedAt
}

model ProductCurrencyPrice {
  id          String    @id @default(cuid())
  productId   String
  currency    String    // USD, EUR, etc
  price       Float     // Price in foreign currency

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, currency])
  @@index([productId])
}

// ───── Settings ──────────────────────────────────────────────────────────────
model SiteSettings {
  id                    String    @id @default("main") // Single record

  maintenanceMode       Boolean   @default(false)
  maintenanceMessage    String?
  maintenanceAllowAdmins Boolean  @default(true)

  updatedAt             DateTime  @updatedAt
}

// ───── Proforma Invoices ────────────────────────────────────────────────────
model Proforma {
  id                           String   @id @default(cuid())
  proformaNumber               String   @unique
  dealerId                     String?
  customerId                   String?
  customerName                 String
  customerAddress              String
  customerCity                 String
  customerPhone                String?
  customerEmail                String?

  status                       String   @default("draft")
  templateType                 String   @default("LOCAL")

  companyName                  String
  companyAddress               String
  companyPhone                 String
  companyEmail                 String
  companyBank                  String?
  companyBankAccount           String?

  // International export fields
  internationalInvoiceNumber   String?
  internationalInvoiceDate     DateTime?
  exporterRef                  String?
  countryOrigin                String?
  countryDestination           String?
  preCarriage                  String?
  portLoading                  String?
  portDischarge                String?
  vessel                       String?

  subtotal                     Decimal  @db.Decimal(12, 2) @default(0)
  shipping                     Decimal  @db.Decimal(12, 2) @default(0)
  tax                          Decimal  @db.Decimal(12, 2) @default(0)
  totalAmount                  Decimal  @db.Decimal(12, 2) @default(0)

  pdfUrl                       String?
  pdfGeneratedAt               DateTime?

  generatedBy                  String?
  generatedAt                  DateTime @default(now())
  viewedAt                     DateTime?
  downloadedAt                 DateTime?

  items                        ProformaItem[]

  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@index([dealerId])
  @@index([customerId])
  @@index([templateType])
  @@index([generatedAt])
}

model ProformaItem {
  id           String   @id @default(cuid())
  proformaId   String
  proforma     Proforma @relation(fields: [proformaId], references: [id], onDelete: Cascade)

  sku          String
  productName  String
  description  String
  brand        String?

  quantity     Decimal  @db.Decimal(10, 2)
  unitPrice    Decimal  @db.Decimal(10, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)

  imageUrl     String?

  createdAt    DateTime @default(now())

  @@index([proformaId])
  @@index([sku])
}

// ───── Promo Codes ─────────────────────────────────────────────────────────
model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  discountType    String    @default("PERCENTAGE") // PERCENTAGE | FIXED_AMOUNT
  discountValue   Decimal   @default(0) @db.Decimal(10,2)
  minOrderAmount  Decimal?  @db.Decimal(12,2)
  usageLimit      Int       @default(0)
  usedCount       Int       @default(0)
  dealerOnly      Boolean   @default(false)
  isActive        Boolean   @default(true)
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

// ───── Site Content (CMS) ──────────────────────────────────────────────────
model SiteContent {
  id          String   @id @default("hero")
  headline    String   @default("Premium işçilik, profesyonel tedarik.")
  subheading  String   @default("23 yıllık tecrübemizle, 4000+ ürün ve 50+ markayı Türkiye genelinde 300+ bayiye ulaştırıyoruz.")
  imageUrl    String?
  ctaText     String   @default("Ürünleri Keşfedin")
  ctaLink     String   @default("/urunler")
  secondaryCtaText String? @default("Bayi Olun")
  secondaryCtaLink String? @default("/bayilik")
  stats       String?  // JSON: [{label:"23+ Yıl",value:"Tecrübe"},...]
  updatedAt   DateTime @updatedAt
}

// ───── Discounts ───────────────────────────────────────────────────────────
model Discount {
  id           String       @id @default(cuid())
  type         DiscountType
  targetId     String       // Product ID, category slug, or brand slug
  targetName   String       // Display name
  discountType DiscountKind @default(PERCENTAGE)
  value        Float
  isActive     Boolean      @default(true)
  validFrom    DateTime     @default(now())
  validUntil   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([type])
  @@index([isActive])
}

enum DiscountType {
  PRODUCT
  CATEGORY
  BRAND
}

enum DiscountKind {
  PERCENTAGE
  FIXED_AMOUNT
}

// ───── Popup / Campaign Management ────────────────────────────────────────────
model Popup {
  id            String        @id @default(cuid())
  title         String
  bodyHtml      String?
  imageUrl      String?
  ctaText       String?
  ctaUrl        String?
  audience      PopupAudience @default(ALL)
  dealerIds     String[]      @default([]) // Specific dealer IDs when audience=SPECIFIC_DEALER
  isActive      Boolean       @default(false)
  showOnce      Boolean       @default(true)
  startDate     DateTime?
  endDate       DateTime?
  impressions   Int           @default(0)
  clicks        Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([isActive])
  @@index([audience])
}

enum PopupAudience {
  ALL
  B2C
  B2B
  SPECIFIC_DEALER
}

// ───── Notify Requests (Back-in-stock) ────────────────────────────────────────
model NotifyRequest {
  id          String   @id @default(cuid())
  productId   String
  userId      String
  channel     String   @default("email") // email, whatsapp
  status      String   @default("pending") // pending, notified, cancelled
  createdAt   DateTime @default(now())
  notifiedAt  DateTime?

  @@unique([productId, userId, channel])
  @@index([productId])
  @@index([status])
}

// ───── Audit ─────────────────────────────────────────────────────────────────
model AuditLog {
  id          String    @id @default(cuid())
  userId      String?   // Who did it
  email       String?   // Email at time

  action      String    // product.update, order.approve, etc
  entity      String    // Product, Order, Dealer
  entityId    String    // ID of the entity

  oldValue    String?   // JSON
  newValue    String?   // JSON

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
}
