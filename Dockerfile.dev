# ============================================================================
# Unified Development Dockerfile (monorepo)
# Single image used by api, storefront, admin services in docker-compose.dev.yml
# Per-service production Dockerfiles remain under apps/*/Dockerfile
# ============================================================================
FROM node:20-alpine

# libc6-compat: required by Prisma engines and some native binaries on Alpine
# bash: nicer shell for "sh -c" commands and debugging
RUN apk add --no-cache libc6-compat bash \
 && corepack enable \
 && corepack prepare pnpm@8.15.0 --activate

WORKDIR /app

# ----------------------------------------------------------------------------
# Layer 1: workspace manifests + prisma schemas (for postinstall hooks)
# Re-install only triggers when a package.json, lockfile, or prisma schema changes
# ----------------------------------------------------------------------------
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* .env* ./
COPY apps/api/package.json        ./apps/api/
COPY apps/storefront/package.json ./apps/storefront/
COPY apps/admin/package.json      ./apps/admin/
COPY packages/shared/package.json ./packages/shared/
COPY packages/ui/package.json     ./packages/ui/

# Copy Prisma schemas (needed for postinstall hooks)
COPY apps/api/prisma              ./apps/api/prisma/
COPY packages/shared/prisma       ./packages/shared/prisma/
COPY prisma                       ./prisma/

# Install full workspace deps (dev included). Dev mode: flexibility over strict lockfile.
RUN pnpm install --no-frozen-lockfile

# Layer 2a: API source + initial build (so dist/ exists for watch mode)
COPY apps/api/src                 ./apps/api/src/
COPY apps/api/tsconfig.json       ./apps/api/
COPY apps/api/nest-cli.json       ./apps/api/

# Build API once so nest start --watch has dist/ to work with
RUN pnpm -F @sadoksan/api build

# ----------------------------------------------------------------------------
# Layer 2: source code
# In docker-compose.dev.yml we override these paths with bind mounts for HMR.
# This COPY exists so the image is also runnable standalone (e.g. CI).
# ----------------------------------------------------------------------------
COPY . .

EXPOSE 3000 3001 3002

# Default command is overridden by docker-compose per service.
CMD ["pnpm", "-r", "--parallel", "run", "dev"]
