# ============================================================================
# Sadöksan ERP — Environment Variables
# ============================================================================
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizle doldurun.
# .env dosyası ASLA repoya commitlenmez (.gitignore'da var).
# ============================================================================

# ─── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://sadoksan:SADOKSAN_DB_PASSWORD@postgres:5432/sadoksan"
POSTGRES_USER="sadoksan"
POSTGRES_PASSWORD="SADOKSAN_DB_PASSWORD"
POSTGRES_DB="sadoksan"

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL="redis://redis:6379"

# ─── API ───────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV="production"

# ─── CORS (virgülle ayrılmış domain listesi) ──────────────────────────────
CORS_ORIGINS="https://sadoksaninsaat.com.tr,https://www.sadoksaninsaat.com.tr"

# ─── Storefront ────────────────────────────────────────────────────────────
NUXT_PUBLIC_API_BASE="https://api.sadoksaninsaat.com.tr"
NUXT_PUBLIC_WHATSAPP_PHONE="905551234567"

# ─── Admin ─────────────────────────────────────────────────────────────────
ADMIN_API_BASE="http://api:3001"

# ─── JWT (Production'da güçlü random string olmalı!) ─────────────────────
JWT_SECRET="CHANGE_ME_GENERATE_RANDOM_64_CHAR_STRING"
JWT_EXPIRES_IN="7d"

# ─── Netsis NetOpenX REST Entegrasyonu (API bilgileri gelince doldurulacak) ─
# Netsis'in kurulu olduğu Windows sunucuda NetOpenX REST servisi çalışıyor olmalı.
# API dokümantasyonu: http://<netsis-sunucu>:7070/api/v2/help
NETSIS_API_URL=""          # Örn: http://192.168.1.100:7070
NETSIS_USER=""             # Netsis kullanıcı adı
NETSIS_PASSWORD=""          # Netsis şifresi
NETSIS_DB_NAME=""           # Veritabanı/şirket adı (örn: REMDA2016)
NETSIS_DB_USER=""           # SQL kullanıcı adı (örn: TEMELSET)
NETSIS_DB_PASSWORD=""       # SQL şifresi (VT_GUVENLIK kapalıysa boş)
NETSIS_BRANCH_CODE="0"      # Şube kodu (default 0)

# ─── Alneo E-Fatura (API bilgileri gelince doldurulacak) ─────────────────
ALNEO_API_URL=""
ALNEO_API_KEY=""
ALNEO_OAUTH_CLIENT_ID=""
ALNEO_OAUTH_CLIENT_SECRET=""

# ─── Albaraka Sanal POS (API bilgileri gelince doldurulacak) ─────────────
ALBARAKA_API_URL=""
ALBARAKA_MERCHANT_ID=""

# ─── WhatsApp (Stok habercisi için) ───────────────────────────────────────
WHATSAPP_PHONE="905551234567"

# ─── E-posta Bildirimleri ─────────────────────────────────────────────────
NOTIFICATION_EMAIL="sadoksan@sadoksaninsaat.com.tr"

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL="info"

# ─── Backup ────────────────────────────────────────────────────────────────
BACKUP_DIR="./backups"
RETENTION_DAYS="30"
